# Normalize line endings in the repository to LF.
# All text files are stored with LF in git.
# On Windows with core.autocrlf=true, checkout converts LF -> CRLF,
# but the eol=lf override below forces LF for .cs files on all platforms.

# Default: auto-detect text files and normalize to LF in git storage
* text=auto

# C# source and project files: always LF in git and on checkout
*.cs      text eol=lf
*.csproj  text eol=lf
*.sln     text eol=lf
*.props   text eol=lf
*.targets text eol=lf

# Web / config files
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.md      text eol=lf
*.sh      text eol=lf
*.ps1     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.jsx     text eol=lf
*.css     text eol=lf
*.html    text eol=lf
*.xml     text eol=lf
*.config  text eol=lf
Dockerfile text eol=lf

# Binary files — do not modify
*.png     binary
*.jpg     binary
*.gif     binary
*.ico     binary
*.zip     binary
*.dll     binary
*.exe     binary
