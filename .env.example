# HealthQ Copilot — Local Development Environment Variables
#
# Copy this file to .env and customise values before running `docker compose up`.
# The .env file is gitignored and must never be committed.
#
# All defaults below work out-of-the-box for local development.

# ── PostgreSQL (local containers only) ────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=devpassword123

# ── SQL Server (Azure Service Bus emulator) ───────────────────────────────────
SA_PASSWORD=ServiceBus!Dev123
